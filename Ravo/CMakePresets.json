{
  "version": 6,
  "include": [
    "../CMakePresets.json"
  ],
  "configurePresets": [
    {
      "name": "ravo_win_msvc_debug",
      "displayName": "Ravo Windows MSVC Debug",
      "inherits": "win_msvc_debug",
      "binaryDir": "${sourceDir}/../build/${presetName}",
      "installDir": "${sourceDir}/../install/${presetName}",
      "cacheVariables": {
        "CMAKE_C_COMPILER": null,
        "PKG_CONFIG_EXECUTABLE": null
      }
    },
    {
      "name": "ravo_win_msvc_release",
      "displayName": "Ravo Windows MSVC Release",
      "inherits": "win_msvc_release",
      "binaryDir": "${sourceDir}/../build/${presetName}",
      "installDir": "${sourceDir}/../install/${presetName}",
      "cacheVariables": {
        "CMAKE_C_COMPILER": null,
        "PKG_CONFIG_EXECUTABLE": null
      }
    }
  ],
  "buildPresets": [
    {
      "name": "ravo_win_msvc_debug",
      "configurePreset": "ravo_win_msvc_debug"
    },
    {
      "name": "ravo_win_msvc_release",
      "configurePreset": "ravo_win_msvc_release"
    }
  ],
  "testPresets": [
    {
      "name": "ravo_win_msvc_debug",
      "configurePreset": "ravo_win_msvc_debug",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
