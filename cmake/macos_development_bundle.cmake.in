# Assemble the build-tree application with real, bundle-owned project code.
# Third-party dependencies deliberately remain external until package-macos.

set(_bundle "@DARKTABLE_APP_BUNDLE_DIR@")
set(_contents "${_bundle}/Contents")
set(_resources "${_contents}/Resources")
set(_frameworks "${_contents}/Frameworks")
set(_source_library_root "@DARKTABLE_APP_LIBRARY_ROOT@")
set(_source_share_root "@DARKTABLE_APP_SHARE_ROOT@")
set(_source_core "@DARKTABLE_BINDIR@/libdarktable.dylib")
set(_stamp "@DARKTABLE_DEVELOPMENT_BUNDLE_STAMP@")
set(_entitlements "@CMAKE_SOURCE_DIR@/packaging/macos/entitlements.plist")

function(_sign_development_code _path)
  execute_process(
    COMMAND /usr/bin/codesign --force --sign - ${ARGN} "${_path}"
    RESULT_VARIABLE _result
    OUTPUT_VARIABLE _output
    ERROR_VARIABLE _error)
  if(NOT _result EQUAL 0)
    message(FATAL_ERROR "codesign failed for ${_path}:\n${_output}${_error}")
  endif()
endfunction()

if(NOT _bundle MATCHES "^@CMAKE_BINARY_DIR@/.+\\.app$")
  message(FATAL_ERROR "refusing to assemble an unexpected application path: ${_bundle}")
endif()
if(NOT IS_DIRECTORY "${_contents}")
  message(FATAL_ERROR "development application was not built: ${_bundle}")
endif()
if(NOT IS_DIRECTORY "${_source_library_root}/darktable")
  message(FATAL_ERROR "development modules are missing: ${_source_library_root}/darktable")
endif()
if(NOT IS_DIRECTORY "${_source_share_root}")
  message(FATAL_ERROR "development shared data is missing: ${_source_share_root}")
endif()
if(NOT EXISTS "${_source_core}")
  message(FATAL_ERROR "development core library is missing: ${_source_core}")
endif()

# The darktable target initially creates convenience symlinks so a targeted
# executable build remains usable.  A complete build replaces only these exact
# bundle-local paths with owned files before signing.
file(REMOVE_RECURSE "${_resources}/lib")
file(MAKE_DIRECTORY "${_resources}/lib/darktable")
file(GLOB_RECURSE _source_modules LIST_DIRECTORIES FALSE
     "${_source_library_root}/darktable/*.so")
if(NOT _source_modules)
  message(FATAL_ERROR "development modules were not built: ${_source_library_root}/darktable")
endif()
foreach(_source_module IN LISTS _source_modules)
  file(RELATIVE_PATH _relative_module
       "${_source_library_root}/darktable" "${_source_module}")
  get_filename_component(_relative_directory "${_relative_module}" DIRECTORY)
  set(_destination_directory
      "${_resources}/lib/darktable/${_relative_directory}")
  file(MAKE_DIRECTORY "${_destination_directory}")
  file(COPY "${_source_module}" DESTINATION "${_destination_directory}")
endforeach()

# Launch Services rejects bundles that point outside their Contents directory.
# Keep the development data tree owned by the bundle just like its modules.
file(REMOVE_RECURSE "${_resources}/share")
file(COPY "${_source_share_root}" DESTINATION "${_resources}")

file(REMOVE "${_frameworks}/libdarktable.dylib")
file(COPY "${_source_core}" DESTINATION "${_frameworks}")

file(GLOB_RECURSE _modules LIST_DIRECTORIES FALSE
     "${_resources}/lib/darktable/*.so")
list(SORT _modules)
foreach(_module IN LISTS _modules)
  _sign_development_code("${_module}")
endforeach()

_sign_development_code("${_frameworks}/libdarktable.dylib")
_sign_development_code("${_bundle}" --entitlements "${_entitlements}")

file(TOUCH "${_stamp}")
