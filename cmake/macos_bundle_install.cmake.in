# Finalize the installed darktable.app after CMake has installed all project
# targets and data in its conventional prefix layout.  The development bundle
# intentionally uses build-tree links for fast iteration; an installed app
# must instead carry its own project runtime files.

set(_bundle "$ENV{DESTDIR}${CMAKE_INSTALL_PREFIX}/darktable.app")
set(_contents "${_bundle}/Contents")
set(_resources "${_contents}/Resources")
set(_legacy_library_root "$ENV{DESTDIR}${CMAKE_INSTALL_PREFIX}/@CMAKE_INSTALL_LIBDIR@/darktable")
set(_legacy_share_root "$ENV{DESTDIR}${CMAKE_INSTALL_PREFIX}/@CMAKE_INSTALL_DATADIR@")

if(NOT IS_DIRECTORY "${_contents}")
  message(FATAL_ERROR "darktable.app was not installed before its runtime files")
endif()
if(NOT IS_DIRECTORY "${_legacy_library_root}")
  message(FATAL_ERROR "DarkTableNext libraries are missing from the install prefix: ${_legacy_library_root}")
endif()
if(NOT IS_DIRECTORY "${_legacy_share_root}")
  message(FATAL_ERROR "DarkTableNext data files are missing from the install prefix: ${_legacy_share_root}")
endif()

# These paths are created as symlinks only in the build tree.  They are exact,
# bundle-local paths here, so removing them cannot affect the source or build
# directory.
file(REMOVE_RECURSE "${_resources}/lib")
file(COPY "${_legacy_library_root}" DESTINATION "${_resources}/lib")
file(REMOVE_RECURSE "${_resources}/share")
file(COPY "${_legacy_share_root}" DESTINATION "${_resources}")

# The installed executable uses Contents/Resources/lib/darktable.  Frameworks
# may remain as the standard bundle directory, but it must not retain the
# development-tree link created by the POST_BUILD command.
file(REMOVE "${_contents}/Frameworks/libdarktable.dylib")
