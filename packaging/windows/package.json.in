{
  "app": {
    "name": "DarkTableNext",
    "executable": "darktable.exe",
    "displayName": "DarkTableNext",
    "manufacturer": "NorthBoundWisdom",
    "version": "@PROJECT_VERSION@",
    "upgradeCode": "@DARKTABLE_WINDOWS_UPGRADE_CODE@"
  },
  "paths": {
    "sourceDir": "@CMAKE_SOURCE_DIR@",
    "binaryDir": "@CMAKE_BINARY_DIR@",
    "buildBinDir": "@DARKTABLE_BINDIR@",
    "stageDir": "@DARKTABLE_WINDOWS_PACKAGE_STAGE@",
    "workDir": "@DARKTABLE_WINDOWS_PACKAGE_WORK@",
    "outputMsi": "@DARKTABLE_WINDOWS_PACKAGE_MSI@"
  },
  "windows": {
    "runtimeRoot": "@DARKTABLE_WINDOWS_RUNTIME_ROOT@",
    "candle": "@DT_WIX_CANDLE_EXECUTABLE@",
    "light": "@DT_WIX_LIGHT_EXECUTABLE@",
    "dumpbin": "@DT_DUMPBIN_EXECUTABLE@",
    "glibCompileSchemas": "@DT_GLIB_COMPILE_SCHEMAS_EXECUTABLE@",
    "iconPng": "@CMAKE_SOURCE_DIR@/data/pixmaps/256x256/darktable.png",
    "sourceLicenses": [
      {
        "source": "@CMAKE_SOURCE_DIR@/LICENSE",
        "destination": "share/licenses/DarkTableNext/LICENSE"
      },
      {
        "source": "@CMAKE_SOURCE_DIR@/build/dependency_source_roots/rawspeed/LICENSE",
        "destination": "share/licenses/rawspeed/LICENSE"
      },
      {
        "source": "@CMAKE_SOURCE_DIR@/build/dependency_source_roots/LibRaw/COPYRIGHT",
        "destination": "share/licenses/LibRaw/COPYRIGHT"
      },
      {
        "source": "@CMAKE_SOURCE_DIR@/build/dependency_source_roots/LibRaw/LICENSE.CDDL",
        "destination": "share/licenses/LibRaw/LICENSE.CDDL"
      },
      {
        "source": "@CMAKE_SOURCE_DIR@/build/dependency_source_roots/LibRaw/LICENSE.LGPL",
        "destination": "share/licenses/LibRaw/LICENSE.LGPL"
      }
    ]
  }
}
