{
  "app": {
    "name": "darktable",
    "displayName": "darktable",
    "version": "@PROJECT_VERSION@"
  },
  "paths": {
    "sourceDir": "@CMAKE_SOURCE_DIR@",
    "binaryDir": "@CMAKE_BINARY_DIR@",
    "targetPath": "@DARKTABLE_PACKAGE_STAGE@/darktable.app/Contents/MacOS/darktable",
    "distDir": "@DARKTABLE_PACKAGE_DIST_DIR@"
  },
  "resources": {
    "copyTrees": [
      {
        "source": "@DARKTABLE_GDK_PIXBUF_MODULE_DIR@",
        "destination": "gtk-runtime/gdk-pixbuf/loaders"
      }
    ],
    "copyFiles": [
      {
        "source": "@DARKTABLE_GDK_PIXBUF_MODULE_CACHE@",
        "destinationDir": "gtk-runtime/gdk-pixbuf"
      }
    ]
  },
  "mac": {
    "bundlePath": "@DARKTABLE_PACKAGE_STAGE@/darktable.app",
    "entitlementsFile": "@CMAKE_SOURCE_DIR@/packaging/macos/entitlements.plist",
    "deploymentTool": "native",
    "librarySearchPaths": ["@HOMEBREW_PREFIX@"],
    "normalizeRpaths": true,
    "signIdentity": "@DT_MACOS_CODESIGN_IDENTITY@",
    "dmgOutputPath": "@DARKTABLE_PACKAGE_DMG@",
    "dmgVolumeName": "darktable @PROJECT_VERSION@"
  }
}
