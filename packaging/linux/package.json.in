{
  "app": {
    "name": "darktable",
    "displayName": "DarkTableNext",
    "version": "@PROJECT_VERSION@"
  },
  "paths": {
    "sourceDir": "@CMAKE_SOURCE_DIR@",
    "binaryDir": "@CMAKE_BINARY_DIR@",
    "appDir": "@DARKTABLE_LINUX_APPDIR@",
    "workDir": "@DARKTABLE_LINUX_PACKAGE_WORK@",
    "outputAppImage": "@DARKTABLE_LINUX_APPIMAGE@"
  },
  "linux": {
    "architecture": "x86_64",
    "appImageTool": "@DARKTABLE_APPIMAGETOOL@",
    "appImageRuntime": "@DARKTABLE_APPIMAGE_RUNTIME@",
    "iconPng": "@CMAKE_SOURCE_DIR@/data/pixmaps/256x256/darktable.png",
    "gdkPixbufLoaderDir": "@DARKTABLE_GDK_PIXBUF_MODULE_DIR@",
    "gdkPixbufQueryLoaders": "@DT_GDK_PIXBUF_QUERY_LOADERS@",
    "gtkLibDir": "@DARKTABLE_GTK_LIBDIR@",
    "gtkBinaryVersion": "@DARKTABLE_GTK_BINARY_VERSION@",
    "gtkQueryImmodules": "@DT_GTK_QUERY_IMMODULES@",
    "gioModuleDir": "@DARKTABLE_GIO_MODULE_DIR@",
    "glibSchemaDir": "@DARKTABLE_GLIB_SCHEMA_DIR@",
    "glibCompileSchemas": "@DT_GLIB_COMPILE_SCHEMAS@",
    "iconThemeDir": "@DARKTABLE_ICON_THEME_DIR@",
    "fontconfigDir": "@DARKTABLE_FONTCONFIG_DIR@",
    "homebrewCellar": "@DARKTABLE_HOMEBREW_CELLAR@",
    "runtimeSearchDirs": [
      "@DARKTABLE_HOMEBREW_PREFIX@/lib",
      "@DARKTABLE_OPENMP_RUNTIME_DIR@"
    ],
    "sourceLicenses": [
      {
        "source": "@CMAKE_SOURCE_DIR@/LICENSE",
        "destination": "DarkTableNext/LICENSE"
      },
      {
        "source": "@CMAKE_SOURCE_DIR@/build/dependency_source_roots/rawspeed/LICENSE",
        "destination": "rawspeed/LICENSE"
      },
      {
        "source": "@CMAKE_SOURCE_DIR@/build/dependency_source_roots/LibRaw/COPYRIGHT",
        "destination": "LibRaw/COPYRIGHT"
      },
      {
        "source": "@CMAKE_SOURCE_DIR@/build/dependency_source_roots/LibRaw/LICENSE.CDDL",
        "destination": "LibRaw/LICENSE.CDDL"
      },
      {
        "source": "@CMAKE_SOURCE_DIR@/build/dependency_source_roots/LibRaw/LICENSE.LGPL",
        "destination": "LibRaw/LICENSE.LGPL"
      }
    ]
  }
}
