#!/bin/bash

# To run darktable-cli must be found, either
#
#   1. Put darktable-cli in the PATH
#   2. Set DARKTABLE_CLI to the full pathname of darktable-cli executable
#   3. Have installed darktable to test in /opt/darktable
#
# To run the test suite:
#
#   ./run               - will run all tests
#   ./run 0001-exposure - will run the single test 0001-exposure
#
# Options:
#
#   --disable-opencl           - do not run the OpenCL path
#   --disable-timing           - do not output timing
#   --no-deltae                - do a light check not requiring Delta-E module
#   --fast-fail                - abort testing on the first NOK test
#   --op=<n> | --operation=<n> - run test with matching operation n
#   --update-expected           - replace CPU baselines with current CPU output
#   --update-opencl-expected    - replace CPU/OpenCL pixel-difference limits

CDPATH=

# If DARKTABLE_CLI not set and darktable-cli not found in the PATH but found
# in standard installation /opt/darktable, use it.
if [[ -z $DARKTABLE_CLI ]] &&
       [[ -z $(command -v darktable-cli) ]] &&
       [[ -f /opt/darktable/bin/darktable-cli ]];
then
    DARKTABLE_CLI=/opt/darktable/bin/darktable-cli
fi

CLI=${DARKTABLE_CLI:-darktable-cli}
TEST_IMAGES=$PWD/images
LOGDIR=$(pwd)/logs
LOG=$LOGDIR/test-$(date +"%Y%m%d-%H%M%S").log
PERF_LOG=$LOGDIR/perfs.log
PERF_ANALYZE=$LOGDIR/perfs-analyze.txt
TESTS=""
TEST_COUNT=0
TEST_ERROR=0
TEST_FAILED=()
COMPARE=$(command -v compare)
DO_OPENCL=yes
DO_TIMING=yes
DO_DELTAE=yes
DO_FAST_FAIL=no
DO_GDB=no
DO_GDB_CL=no
DO_UPDATE_EXPECTED=no
DO_UPDATE_OPENCL_EXPECTED=no

mkdir -p "$LOGDIR"

# echo on console and write to log file
function e()
{
    echo "$*" | tee -a "$LOG"
}

function call()
{
    local TEST=$1
    local CL=$2

    shift 2
    local FIRST=$1

    local TIMEFORMAT="%2R"

    if [[ $FIRST == gdb ]]; then
        "$@" 2> /dev/null
    elif [[ $DO_TIMING != yes ]]; then
        "$@" 1> /dev/null
        return $?
    else
        TIME=$( { time "$@" 1> /dev/null; } 2>&1 )
        res=$?

        echo "$(date +'%Y-%m-%d %H:%M:%S'),\"${TEST}-${CL}\",$TIME" >> "$PERF_LOG"
        e "      Timing $CL ${TIME}s"
        return $res
    fi
}

function get-diff()
{
    local RESULT_VAR=$1
    local FROM=$2
    local TO=$3
    local DIFF=$4
    local NBPIX=0

    # compute diff image
    if [[ -n $COMPARE ]]; then
        "$COMPARE" -metric AE "$FROM" "$TO" "$DIFF" 1>/dev/null 2>&1
    fi

    # compute pixels diff
    if [[ -f $FROM ]]; then
        NBPIX=$(../count-diff-pixels "$FROM" "$TO") || NBPIX=50000
    fi

    printf -v "$RESULT_VAR" '%s' "$NBPIX"
    [[ "$NBPIX" == 0 ]] && return 0 || return 1
}

[[ -z $(command -v "$CLI") ]] && echo "Make sure $CLI is in the path" && exit 1

while [[ $# -gt 0 ]]; do
    case $1 in
        --disable-opencl)
            DO_OPENCL=no
            ;;
        --disable-timing)
            DO_TIMING=no
            ;;
        --gdb-cl)
            DO_GDB_CL=yes
            ;;
        --gdb)
            DO_GDB=yes
            ;;
        --no-deltae)
            DO_DELTAE=no
            ;;
        --fast-fail)
            DO_FAST_FAIL=yes
            ;;
        --update-expected)
            DO_UPDATE_EXPECTED=yes
            ;;
        --update-opencl-expected)
            DO_UPDATE_OPENCL_EXPECTED=yes
            ;;
        --op|--operation)
            [[ $# -lt 2 ]] && echo "error: $1 requires an argument" && exit 1
            shift
            OP=$1
            TESTS=$(grep -l "operation=\"$OP\"" */*.xmp | while read -r xmp; do dirname "$xmp"; done)
            [[ -z "$TESTS" ]] && echo error: operation $OP did not match any test && exit 1
            ;;
        --op=*|--operation=*)
            OP=${1#*=}
            TESTS=$(grep -l "operation=\"$OP\"" */*.xmp | while read -r xmp; do dirname "$xmp"; done)
            [[ -z "$TESTS" ]] && echo error: operation $OP did not match any test && exit 1
            ;;
        --)
            shift
            while [[ $# -gt 0 ]]; do
                arg=${1%/}
                TESTS="$TESTS ${arg##*/}"
                shift
            done
            break
            ;;
        --*)
            echo "error: unknown option $1"
            exit 1
            ;;
        *)
            arg=${1%/}
            TESTS="$TESTS ${arg##*/}"
            ;;
    esac
    shift
done

# expected.png is the deterministic CPU reference. Updating it must never also
# exercise the OpenCL path, whose output is checked separately against CPU.
if [[ $DO_UPDATE_EXPECTED == yes ]]; then
    DO_OPENCL=no
    echo "Updating expected.png files from current CPU output (OpenCL disabled)"
fi

if [[ $DO_UPDATE_OPENCL_EXPECTED == yes ]]; then
    if [[ $DO_OPENCL != yes ]]; then
        echo "error: --update-opencl-expected requires OpenCL"
        exit 1
    fi
    echo "Updating cpugpu.maxpix files from current CPU/OpenCL output"
fi

# No test specified, run all of them
[[ -z "$TESTS" ]] && TESTS="$(ls -d [0-9]*)"

[[ $DO_GDB == yes ]] &&
    GDB_CLI="gdb --args"

[[ $DO_GDB_CL == yes ]] &&
    GDB_CLI_CL="gdb --args"

for dir in $TESTS; do
    # Read optional CONFIG file, add corresponding options
    config=""
    if [[ -f $dir/CONFIG ]]; then
        while read -r confstr; do
	    config+=" --conf $confstr"
        done < "$dir/CONFIG"
    fi

    # Read option README, add first line as hint message
    label="$dir"
    if [[ -f $dir/README ]]; then
        label+=" ($(head -1 $dir/README))"
    fi
    e Test $label

    TEST_COUNT=$((TEST_COUNT + 1))

    if [[ -f $dir/test.sh ]]; then
        # The test has a specific driver
        (
            $dir/test.sh
        )

        if [[ $? = 0 ]]; then
            e "  OK"
        else
            e "  FAILS: specific test"
            TEST_ERROR=$((TEST_ERROR + 1))
            TEST_FAILED+=($dir)
        fi

    else
        # A standard test
        #   - xmp to create the output
        #   - expected. is the expected output
        #   - a diff is made to compute the max Delta-E
        (
            cd $dir

            # remove leading "????-"

            TEST=${dir:5}

            [[ ! -f $TEST.xmp ]] &&
                e missing $dir.xmp && exit 1

            [[ ! -f expected.png ]] && e "      missing expected.png"

            IMAGE=$(grep DerivedFrom $TEST.xmp | cut -d'"' -f2)

            e "      Image $IMAGE"

            # Remove previous output and diff if any

            rm -f output*.png diff*.png

            # Create the output
            #
            # Note that we force host_memory_limit has this will have
            # impact on the tiling and will change the output.
            #
            # This means that the tiling algorithm is probably broken.
            #

            # All common core options:
            CORE_OPTIONS="--configdir /tmp/darktable-test \
                 --conf host_memory_limit=8192 \
                 --conf resourcelevel=reference \
                 --conf worker_threads=4 -t 4 \
                 --conf clplatform_other=TRUE \
                 --conf opencl_fast=FALSE \
                 --conf plugins/lighttable/export/force_lcms2=FALSE \
                 --conf plugins/lighttable/export/pixel_interpolator=lanczos3 \
                 --conf plugins/lighttable/export/pixel_interpolator_warp=bicubic \
                 --conf plugins/lighttable/export/iccintent=0"

            # Some // loops seems to not honor the omp_set_num_threads() in
            # darktable.c (this is needed to run 0068-rawdenoise-xtrans on
            # different configurations)

            export OMP_THREAD_LIMIT=4
            export OMP_NUM_THREADS=4

            call $dir cpu $GDB_CLI $CLI --width 2048 --height 2048 \
                 --hq true --apply-custom-presets false \
                 "$TEST_IMAGES/$IMAGE" "$TEST.xmp" output.png \
                 --core --disable-opencl $CORE_OPTIONS $config

            res=$?
            largepixdiff=0

            if [[ $res -eq 0 ]] && [[ $DO_UPDATE_EXPECTED == yes ]]; then
                if [[ -f output.png ]]; then
                    cp output.png expected.png
                    e "      Updated expected.png"
                else
                    e "  FAILS: CPU output was not created"
                    res=1
                fi
            fi

            if [[ $res != 0 ]]; then
                echo "========== COMMAND fails"
                echo "To reproduce and debug:"
                echo cd $(pwd)\; \
                    gdb --args $CLI --width 2048 --height 2048 \
                         --hq true --apply-custom-presets false \
                         "$TEST_IMAGES/$IMAGE" "$TEST.xmp" output.png \
                         --core --disable-opencl $CORE_OPTIONS $config
            fi


            if [[ $DO_OPENCL == yes ]]; then
                call $dir gpu $GDB_CLI_CL $CLI --width 2048 --height 2048 \
                     --hq true --apply-custom-presets false \
                     "$TEST_IMAGES/$IMAGE" "$TEST.xmp" output-cl.png \
                     --core --conf opencl=TRUE $CORE_OPTIONS $config
                res=$((res + $?))

                if [[ $res != 0 ]]; then
                    echo "========== COMMAND fails"
                    echo "To reproduce and debug:"
                    echo cd $(pwd)\; \
                         gdb --args $CLI --width 2048 --height 2048 \
                         --hq true --apply-custom-presets false \
                         "$TEST_IMAGES/$IMAGE" "$TEST.xmp" output-cl.png \
                         --core --conf opencl=TRUE $CORE_OPTIONS $config
                fi
            fi

            if [[ $res -eq 0 ]] && [[ ! -f expected.png ]]; then
                e "  FAILS: missing expected.png"
                e "         run with --update-expected to create it"
                res=1
            fi

            # If all ok, check Delta-E

            if [[ $res -eq 0 ]]; then
                if [[ $DO_OPENCL == yes ]]; then
                    get-diff DIFFPIX output.png output-cl.png diff-cl.png
                    diffres=$?

                    if [[ $DO_UPDATE_OPENCL_EXPECTED == yes ]]; then
                        printf '%s\n' "$DIFFPIX" > cpugpu.maxpix
                        e "      Updated cpugpu.maxpix to ${DIFFPIX}"
                    fi

                    if [[ $diffres -ne 0 ]]; then
                        e "      CPU & GPU version differ by ${DIFFPIX} pixels"

                        #  if CPU/GPU max pixel exists, check it
                        if [[ -f cpugpu.maxpix ]]; then
                            read -r REF < cpugpu.maxpix
                            if (( DIFFPIX > REF )); then
                                e "      CPU & GPU large difference > $REF"
                                largepixdiff=1
                            elif (( DIFFPIX < (( REF / 10 ) * 8)  )); then
                                e "      CPU & GPU smaller difference old $REF now $DIFFPIX"
                            fi
                        fi

                        if [[ $DO_DELTAE == yes ]]; then
                            e "      CPU vs. GPU report :"
                            ../deltae output.png output-cl.png | tee -a "$LOG"
                            e " "
                        fi
                    fi
                fi

                if [[ $DO_DELTAE == yes ]]; then
                    if [[ -f expected.png ]]; then
                        e "      Expected CPU vs. current CPU report :"
                        ../deltae expected.png output.png | tee -a "$LOG"
                        res=${PIPESTATUS[0]}
                        e " "
                    else
                        false
                        res=$?
                    fi

                    if [[ $res -lt 2 ]]; then
                        e "  OK"
                        if [[ $res = 1 ]]; then
                            get-diff DIFFPIX expected.png output.png diff-ok.png
                        fi
                        res=0

                    else
                        e "  FAILS: image visually changed"
                        if [[ -n $COMPARE ]] && [[ -f expected.png ]]; then
                            get-diff DIFFPIX expected.png output.png diff.png
                            e "         see diff.png for visual difference"
			    e "         (${DIFFPIX} pixels changed)"
                        fi
                    fi
                else
                    get-diff DIFFPIX expected.png output.png diff-ok.png

                    # if we have an exponent just pretend this is a number
                    # above 5000 which is the limit checked below.

                    if [[ $DIFFPIX =~ e ]]; then
                        DIFFPIX=50000
                    fi

                    if [[ $DIFFPIX -lt 5000 ]]; then
                        e "      Light check : OK"
                        res=0
                    else
                        e "      Light check : NOK ($DIFFPIX)"
                        res=1
                    fi
                fi
            else
                e "  FAILS : darktable-cli errored"
                res=1
            fi

            exit $(( $res || $largepixdiff ))
        )

        if [[ $? -ne 0 ]]; then
            TEST_ERROR=$((TEST_ERROR + 1))
            TEST_FAILED+=($dir)

            [[ $DO_FAST_FAIL == yes ]] && break;
        fi
    fi

    e
done

e "Total test $TEST_COUNT"
e "Errors     $TEST_ERROR"

if [[ $TEST_ERROR -gt 0 ]]; then
    for D in "${TEST_FAILED[@]}"; do
        echo "   - $D"
    done
fi

if [[ $DO_TIMING == yes ]]; then
    ./check-performance

    if [[ $? == 1 ]]; then
        echo
        e "Performance regressions:"
        cat $PERF_ANALYZE
    fi
fi

echo "see $(basename $LOG)"
[[ $TEST_ERROR -eq 0 ]]
