#!/usr/bin/env python3

import argparse

import numpy as np
from PIL import Image


def count_different_pixels_numpy(image_path1, image_path2, threshold=0):
    with Image.open(image_path1) as source1, Image.open(image_path2) as source2:
        img1 = source1.convert("RGB")
        img2 = source2.convert("RGB")

        if img1.size != img2.size:
            # A geometry change is always a material regression. Return a value
            # above the runner's light-check threshold instead of aborting and
            # accidentally treating an empty result as zero differences.
            return max(img1.width * img1.height, img2.width * img2.height)

        # Use a signed type so subtraction cannot wrap at the uint8 boundary.
        arr1 = np.asarray(img1, dtype=np.int16)
        arr2 = np.asarray(img2, dtype=np.int16)

    diff = np.abs(arr1 - arr2)
    return int(np.count_nonzero(np.any(diff > threshold, axis=-1)))


if __name__ == "__main__":
    # Set up argument parser
    parser = argparse.ArgumentParser(
        description="Count the number of different pixels between two images."
    )
    parser.add_argument("image1", help="Path to the first image")
    parser.add_argument("image2", help="Path to the second image")
    parser.add_argument(
        "--threshold",
        type=int,
        default=0,
        help="Threshold for pixel difference (default: 0)",
    )

    # Parse arguments
    args = parser.parse_args()

    # Count differences
    differences = count_different_pixels_numpy(args.image1, args.image2, args.threshold)
    print(differences)
