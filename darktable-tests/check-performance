#!/bin/bash

# Check performance data from perfs.log. The script needs at least 7
# report for the same test. An issue is reported if a 10% loss of
# performance is found during the period.

LOGDIR=$(pwd)/logs
PERF_LOG="$LOGDIR/perfs.log"
PERF_ANALYZE="$LOGDIR/perfs-analyze.txt"

# Clear or create output file
> "$PERF_ANALYZE"

# Extract unique tests
COMMANDS=$(awk -F, 'NR>1 {print $2}' "$PERF_LOG" | sort | uniq)

# Analyze each command
for cmd in $COMMANDS; do
    echo "Analyzing: $cmd" >> "$PERF_ANALYZE"
    awk -F, -v cmd="$cmd" -v OFS=, '
    BEGIN {
        N=0
    }
    $2 == cmd {
        time[$1] = $3;
        dates[N] = $1;
        times[N] = $3;
        N++
    }
    END {
        if (N > 7) {
            sum = 0;
            for (j = N-6; j <= N; j++) sum += times[j];
            avg = sum / 7;
            max = avg * 1.15
            if (times[N] > max) {
                print dates[N], "Regression detected: " times[N] " > " max " (10% above 7-day avg)" >> "'"$PERF_ANALYZE"'"
            }
        }
    }' "$PERF_LOG"
done

# Finaly remove entries older than 6 months

if date -v-6m +"%Y-%m-%d" >/dev/null 2>&1; then
    SIX_MONTHS_AGO=$(date -v-6m +"%Y-%m-%d")
else
    SIX_MONTHS_AGO=$(date -d "6 months ago" +"%Y-%m-%d")
fi
awk -v cutoff="$SIX_MONTHS_AGO" '$1 >= cutoff' $PERF_LOG > tmpfile &&
    mv tmpfile $PERF_LOG

grep Regression $PERF_ANALYZE 2>&1 > /dev/null

[[ $? == 1 ]]
